    "defu": "^6.1.4",
    "destr": "^2.0.5",
    "evlog": "^2.18.1",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "h3": "^1.15.4",
    "listhen": "^1.9.0",
    "node-webpmux": "^3.2.1",
    "ofetch": "^1.4.1",
    "ohash": "^1.1.6",
    "pathe": "^2.0.3",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.5",
