{
  "name": "deadbyte-bot",
  "version": "4.0.0",
  "private": true,
  "description": "Runtime do bot DeadByte v4",
  "type": "module",
  "main": "./dist/cli/index.mjs",
  "types": "./dist/cli/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/cli/index.ts start",
